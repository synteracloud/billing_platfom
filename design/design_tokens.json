{
  "$schema": "https://example.com/schemas/design-tokens.schema.json",
  "meta": {
    "name": "billing-platform-design-tokens",
    "version": "1.0.0",
    "description": "Deterministic semantic design token system for enterprise billing interfaces.",
    "principles": [
      "semantic-only",
      "theme-ready",
      "deterministic-rendering",
      "dense-data-readability",
      "no-visual-drift"
    ]
  },
  "color": {
    "light": {
      "background": "#F7F8FA",
      "surface": "#FFFFFF",
      "surfaceElevated": "#FFFFFF",
      "surfaceMuted": "#F3F4F6",
      "text": {
        "primary": "#111827",
        "secondary": "#374151",
        "muted": "#6B7280",
        "inverse": "#F9FAFB"
      },
      "border": {
        "default": "#D1D5DB",
        "subtle": "#E5E7EB",
        "strong": "#9CA3AF"
      },
      "primary": "#2563EB",
      "primaryHover": "#1D4ED8",
      "primaryActive": "#1E40AF",
      "success": "#059669",
      "warning": "#D97706",
      "danger": "#DC2626",
      "info": "#0284C7",
      "focusRing": "#93C5FD",
      "tableHeader": "#F9FAFB",
      "tableRowHover": "#EFF6FF",
      "overlay": "rgba(17, 24, 39, 0.45)"
    },
    "dark": {
      "background": "#0B1220",
      "surface": "#111827",
      "surfaceElevated": "#1F2937",
      "surfaceMuted": "#0F172A",
      "text": {
        "primary": "#F9FAFB",
        "secondary": "#D1D5DB",
        "muted": "#9CA3AF",
        "inverse": "#111827"
      },
      "border": {
        "default": "#374151",
        "subtle": "#1F2937",
        "strong": "#4B5563"
      },
      "primary": "#60A5FA",
      "primaryHover": "#3B82F6",
      "primaryActive": "#2563EB",
      "success": "#34D399",
      "warning": "#FBBF24",
      "danger": "#F87171",
      "info": "#38BDF8",
      "focusRing": "#2563EB",
      "tableHeader": "#0F172A",
      "tableRowHover": "#1E293B",
      "overlay": "rgba(2, 6, 23, 0.7)"
    }
  },
  "spacing": {
    "xs": "4px",
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "24px",
    "2xl": "32px",
    "3xl": "40px"
  },
  "radius": {
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px"
  },
  "typography": {
    "font": {
      "family": {
        "primary": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
        "mono": "'JetBrains Mono', 'SFMono-Regular', Menlo, Monaco, Consolas, monospace"
      },
      "size": {
        "xs": "12px",
        "sm": "13px",
        "md": "14px",
        "lg": "16px",
        "xl": "20px",
        "display": "28px"
      },
      "weight": {
        "normal": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700
      },
      "lineHeight": {
        "xs": 1.4,
        "sm": 1.45,
        "md": 1.5,
        "lg": 1.55,
        "xl": 1.35,
        "display": 1.2
      },
      "letterSpacing": {
        "tight": "-0.01em",
        "normal": "0em",
        "wide": "0.01em"
      }
    }
  },
  "shadow": {
    "sm": "0 1px 2px rgba(15, 23, 42, 0.08)",
    "md": "0 4px 12px rgba(15, 23, 42, 0.12)",
    "lg": "0 12px 28px rgba(15, 23, 42, 0.18)"
  },
  "border": {
    "width": {
      "thin": "1px",
      "default": "2px"
    }
  },
  "zIndex": {
    "base": 1,
    "dropdown": 1000,
    "overlay": 1100,
    "modal": 1200,
    "toast": 1300
  },
  "motion": {
    "duration": {
      "fast": "120ms",
      "normal": "200ms",
      "slow": "320ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.2, 0, 0, 1)",
      "decelerate": "cubic-bezier(0, 0, 0, 1)",
      "accelerate": "cubic-bezier(0.3, 0, 1, 1)"
    }
  },
  "rules": {
    "noDirectColorUsageInComponents": true,
    "allVisualStylesMustUseTokens": true,
    "supportsFutureTheming": true
  }
}
